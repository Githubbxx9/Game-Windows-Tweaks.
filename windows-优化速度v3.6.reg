;;去除搜索页面信息流和热搜
;;Windows10:任务栏右键->搜索->搜索突出显示 [关闭]
;;Windows11:设置->隐私和安全->更多设置->显示搜索要点 [关闭]
[HKEY_CURRENT_USER\Software\Policies\Microsoft\Windows\explorer]
"DisableSearchBoxSuggestions"=dword:00000001

;;内核死锁检测
[HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\Control\Session Manager]
"EnableDeadGwdTimers"=dword:00000001

;帐户: 使用空密码的本地帐户只允许进行控制台登录
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\Lsa]
"LimitBlankPasswordUse"=dword:00000001

;;关机时自动清除运行框的记录的设置方法(1=关机时删除,0=不)
[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer]
"ClearRecentDocsOnExit"=dword:00000001

;;自动卸载没用的DLL文件
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\Currentversion\Explorer]
"AlwaysUnloadDLL"=dword:00000001

;ClearType清晰化技术
[HKEY_CURRENT_USER\Control Panel\Desktop]
"FontSmoothing"="2"
"FontSmoothingGamma"=dword:00000000
"FontSmoothingOrientation"=dword:00000001
"FontSmoothingType"=dword:00000002

;关闭资讯和兴趣
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\PolicyManager\default\Feeds]
"FeedsEnabled"=dword:00000000
[HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\Windows\Windows Feeds]
"EnableFeeds"=dword:00000000